FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Redis (used by Celery and caching)
REDIS_URL=redis://localhost:6379/0

# PDF Storage
# PDF_STORAGE_DIR is auto-resolved to project root in config.py
# Only set this if you want a custom absolute path
# PDF_STORAGE_DIR=/custom/path/to/pdfs
PDF_RETENTION_HOURS=24

# Playwright
PLAYWRIGHT_BROWSER_POOL_SIZE=3
PLAYWRIGHT_RENDER_TIMEOUT_MS=30000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=2

# Rate Limiting
RATE_LIMIT_SINGLE=100/minute
RATE_LIMIT_BULK=10/minute

# Server
HOST=0.0.0.0
PORT=5000
